---
<canvas id="subdivide-demo" style="width:100%;height:400px;border-radius:8px;background:#1a1a2e;display:block;"></canvas>

<script>
  async function init() {
    const { setupScene } = await import('./scene-setup')
    const { icosphere } = await import('../../src')
    const { toThreeMesh } = await import('../../src/three')

    const ctx = await setupScene('subdivide-demo', { cameraPos: [4, 2, 4], target: [0, 0.5, 0] })
    if (!ctx) return

    ctx.scene.add(toThreeMesh(
      icosphere({ radius: 0.5, subdivisions: 0 })
        .translate(-2, 0.5, 0).vertexColor('#cc4444')
    ))
    ctx.scene.add(toThreeMesh(
      icosphere({ radius: 0.5, subdivisions: 0 })
        .subdivideAdaptive(0.3).spherize(0.5)
        .translate(0, 0.5, 0).vertexColor('#44cc44')
    ))
    ctx.scene.add(toThreeMesh(
      icosphere({ radius: 0.5, subdivisions: 0 })
        .subdivideAdaptive(0.3).spherize(0.5)
        .jitter(0.04, { seed: 3 })
        .translate(2, 0.5, 0).vertexColor('#4444cc')
    ))
  }
  init()
</script>
