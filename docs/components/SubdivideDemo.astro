<canvas id="subdivide-demo" style="width:100%;height:400px;border-radius:8px;background:#1a1a2e;display:block;"></canvas>

<script>
  import { setupScene } from './scene-setup'
  import { icosphere } from '../../src'
  import { toThreeMesh } from '../../src/three'

  const ctx = setupScene('subdivide-demo', { cameraPos: [4, 2, 4], target: [0, 0.5, 0] })
  if (ctx) {
    const raw = icosphere({ radius: 0.5, subdivisions: 0 })
      .translate(-2, 0.5, 0).vertexColor('#cc4444')
    ctx.scene.add(toThreeMesh(raw))

    const subdiv = icosphere({ radius: 0.5, subdivisions: 0 })
      .subdivideAdaptive(0.3).spherize(0.5)
      .translate(0, 0.5, 0).vertexColor('#44cc44')
    ctx.scene.add(toThreeMesh(subdiv))

    const organic = icosphere({ radius: 0.5, subdivisions: 0 })
      .subdivideAdaptive(0.3).spherize(0.5)
      .jitter(0.04, { seed: 3 })
      .translate(2, 0.5, 0).vertexColor('#4444cc')
    ctx.scene.add(toThreeMesh(organic))
  }
</script>
