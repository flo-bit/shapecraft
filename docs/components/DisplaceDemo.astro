<canvas id="displace-demo" style="width:100%;height:400px;border-radius:8px;background:#1a1a2e;display:block;"></canvas>

<script>
  async function init() {
    const THREE = await import('three')
    const { OrbitControls } = await import('three/examples/jsm/controls/OrbitControls.js')
    const { icosphere } = await import('shapecraft')
    const { fbm } = await import('shapecraft/noise')
    const { toThreeMesh } = await import('shapecraft/three')

    const canvas = document.getElementById('displace-demo') as HTMLCanvasElement
    if (!canvas) return

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true })
    renderer.setSize(canvas.clientWidth, canvas.clientHeight)
    const scene = new THREE.Scene()
    scene.background = new THREE.Color(0x2a2a3a)
    const camera = new THREE.PerspectiveCamera(50, canvas.clientWidth / canvas.clientHeight, 0.1, 100)
    camera.position.set(3, 2, 3)
    const controls = new OrbitControls(camera, canvas)
    controls.target.set(0, 0.5, 0)
    controls.enableDamping = true
    controls.update()

    scene.add(new THREE.HemisphereLight(0x87ceeb, 0x3a5a2a, 0.6))
    const sun = new THREE.DirectionalLight(0xfff4e0, 1.2)
    sun.position.set(5, 8, 5)
    scene.add(sun)

    const noise = fbm({ seed: 42, scale: 2, octaves: 3 })

    scene.add(toThreeMesh(
      icosphere({ radius: 0.5, subdivisions: 2 }).translate(-1.5, 0.5, 0).vertexColor('#4488cc')
    ))
    scene.add(toThreeMesh(
      icosphere({ radius: 0.5, subdivisions: 2 })
        .displaceNoise(noise, 0.15, { direction: 'radial' })
        .translate(0, 0.5, 0).vertexColor('#cc8844')
    ))
    scene.add(toThreeMesh(
      icosphere({ radius: 0.5, subdivisions: 2 })
        .jitter(0.06, { seed: 7 }).translate(1.5, 0.5, 0).vertexColor('#88cc44')
    ))

    ;(function animate() {
      requestAnimationFrame(animate)
      controls.update()
      renderer.render(scene, camera)
    })()
  }
  init()
</script>
