<canvas id="displace-demo" style="width:100%;height:400px;border-radius:8px;background:#1a1a2e;display:block;"></canvas>

<script>
  import { setupScene } from './scene-setup'
  import { icosphere } from '../../src'
  import { fbm } from '../../src/noise'
  import { toThreeMesh } from '../../src/three'

  const ctx = setupScene('displace-demo', { cameraPos: [3, 2, 3], target: [0, 0.5, 0] })
  if (ctx) {
    const noise = fbm({ seed: 42, scale: 2, octaves: 3 })

    const orig = icosphere({ radius: 0.5, subdivisions: 2 })
      .translate(-1.5, 0.5, 0).vertexColor('#4488cc')
    ctx.scene.add(toThreeMesh(orig))

    const displaced = icosphere({ radius: 0.5, subdivisions: 2 })
      .displaceNoise(noise, 0.15, { direction: 'radial' })
      .translate(0, 0.5, 0).vertexColor('#cc8844')
    ctx.scene.add(toThreeMesh(displaced))

    const jittered = icosphere({ radius: 0.5, subdivisions: 2 })
      .jitter(0.06, { seed: 7 })
      .translate(1.5, 0.5, 0).vertexColor('#88cc44')
    ctx.scene.add(toThreeMesh(jittered))
  }
</script>
