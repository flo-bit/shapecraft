<canvas id="quickstart-demo" style="width:100%;height:400px;border-radius:8px;background:#1a1a2e;display:block;"></canvas>

<script>
  import { setupScene } from './scene-setup'
  import { box, sphere, merge } from '../../src'
  import { toThreeMesh } from '../../src/three'

  const ctx = setupScene('quickstart-demo')
  if (ctx) {
    const b = box({ size: 1 }).vertexColor('#cc8844')
    const s = sphere({ radius: 0.5 }).translate(2, 0, 0).vertexColor('#4488cc')
    const combined = merge(b, s).translate(-1, 0.5, 0)
    ctx.scene.add(toThreeMesh(combined))
  }
</script>
