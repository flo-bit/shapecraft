<canvas id="primitives-demo" style="width:100%;height:400px;border-radius:8px;background:#1a1a2e;display:block;"></canvas>

<script>
  import { setupScene } from './scene-setup'
  import { box, sphere, cylinder, cone, icosphere, torus } from '../../src'
  import { toThreeMesh } from '../../src/three'

  const ctx = setupScene('primitives-demo', { cameraPos: [6, 4, 8], target: [3, 0.5, 0] })
  if (ctx) {
    const primitives = [
      box().vertexColor('#cc8844'),
      sphere().vertexColor('#4488cc'),
      cylinder().vertexColor('#88cc44'),
      cone().vertexColor('#cc4488'),
      icosphere().vertexColor('#44ccaa'),
      torus().vertexColor('#aa44cc'),
    ]
    primitives.forEach((m, i) => {
      ctx.scene.add(toThreeMesh(m.translate(i * 1.5, 0.5, 0)))
    })
  }
</script>
